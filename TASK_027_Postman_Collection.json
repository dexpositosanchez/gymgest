									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.length).to.be.greaterThan(0);",
									"    ",
									"    const routine = jsonData.data[0];",
									"    pm.expect(routine).to.have.property('id');",
									"    pm.expect(routine).to.have.property('starts_at');",
									"    pm.expect(routine).to.have.property('is_current');",
									"    pm.expect(routine).to.have.property('assigned_at');",
									"    pm.expect(routine).to.have.property('routine');",
									"    pm.expect(routine).to.have.property('gym');",
									"    pm.expect(routine).to.have.property('trainer');",
									"});",
									"",
